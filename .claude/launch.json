{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel (PHP Artisan Serve)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--port=8000"],
      "port": 8000
    },
    {
      "name": "Vite (Frontend Assets)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Laravel Queue Worker",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1"],
      "port": null
    },
    {
      "name": "Laravel Pail (Logs)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "pail", "--timeout=0"],
      "port": null,
      "autoPort": true
    }
  ]
}
